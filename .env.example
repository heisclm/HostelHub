# ==========================================
# ENV Variables (Example / Template)
# ==========================================
# Copy this file to `.env` or `.env.local` 
# and fill in your actual credentials.
# NOTE: Variables prefixed with `NEXT_PUBLIC_` 
# are exposed to the browser.
# ==========================================

# ------------------------------------------
# GENERAL APP CONFIG
# ------------------------------------------
# APP_URL: The URL where this application is hosted.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ------------------------------------------
# FIREBASE CREDENTIALS
# ------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY="AIzaSyXXXXXXXXXXXXXXXXXXXX"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-app.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-app-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-app.firebasestorage.app"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="1234567890"
NEXT_PUBLIC_FIREBASE_APP_ID="1:1234567890:web:abcd1234abcd"
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID="G-XXXXXXXXXX"

# ------------------------------------------
# CLOUDINARY (Images & Documents)
# ------------------------------------------
# Go to cloudinary.com -> Dashboard -> Developer Settings
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your_cloud_name"
NEXT_PUBLIC_CLOUDINARY_API_KEY="your_api_key_here"
# KEEP THIS SECRET (Do not add NEXT_PUBLIC_ prefix)
CLOUDINARY_API_SECRET="your_api_secret_here"

# ------------------------------------------
# EMAIL NOTIFICATIONS (Resend)
# ------------------------------------------
# Keep secret - only used in backend API routes
RESEND_API_KEY="re_your_resend_api_key"
# Required for production (e.g., "HostelHub <no-reply@yourdomain.com>")
RESEND_FROM_EMAIL="HostelHub <onboarding@resend.dev>"

# ------------------------------------------
# EMAIL NOTIFICATIONS (SMTP - Legacy)
# ------------------------------------------
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="HostelHub <your-email@gmail.com>"

# ------------------------------------------
# PAYMENTS (e.g., Paystack)
# ------------------------------------------
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Keep secret - only used in backend API routes
PAYSTACK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ------------------------------------------
# SECURITY & CRONS
# ------------------------------------------
CRON_SECRET="your-secure-random-cron-secret-key"
