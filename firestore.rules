rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Global Safety Net
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Global Helpers
    // ===============================================================
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn(); }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isAdmin() {
      return isSignedIn() && (
        // Database check in users collection
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        // Database check in specific admins collection (for root portability)
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // ===============================================================
    // Entity Validators
    // ===============================================================
    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256 &&
             data.role in ['student', 'manager', 'guest', 'admin'] &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100)) &&
             (!('phoneNumber' in data) || (data.phoneNumber is string && data.phoneNumber.size() <= 20)) &&
             data.createdAt == request.time;
    }

    function isValidHostel(data) {
      return data.managerId is string &&
             data.name is string &&
             data.location is string &&
             data.address is string &&
             data.createdAt == request.time;
    }

    function isValidBooking(data) {
      return data.studentId is string && data.studentId.size() <= 128 &&
             data.hostelId is string && data.hostelId.size() <= 128 &&
             data.status in ['pending', 'confirmed', 'cancelled'] &&
             data.amount is number && data.amount >= 0 &&
             data.createdAt == request.time;
    }

    // ===============================================================
    // Collection Matches
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().role != 'admin';
      allow update: if (isOwner(userId) && 
                       incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'phoneNumber', 'updatedAt']) &&
                       incoming().uid == existing().uid &&
                       incoming().email == existing().email &&
                       incoming().role == existing().role &&
                       incoming().updatedAt == request.time) || isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via Firebase Console or Admin SDK for maximum security
    }

    match /hostels/{hostelId} {
      allow read: if true; // Public listings
      allow create: if isVerified() && isValidHostel(incoming()) && isOwner(incoming().managerId);
      allow update: if isAdmin() ||
                       (isOwner(existing().managerId) && 
                        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'location', 'address', 'amenities', 'images', 'policies', 'contactDetails', 'coordinates', 'updatedAt']) &&
                        (!('updatedAt' in incoming()) || incoming().updatedAt == request.time)) ||
                       (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['rating']));
      allow delete: if isAdmin();
      
      match /rooms/{roomId} {
        allow read: if true;
        allow write: if isOwner(get(/databases/$(database)/documents/hostels/$(hostelId)).data.managerId) || isAdmin();
      }

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isVerified() && isOwner(incoming().userId);
        allow update, delete: if isOwner(existing().userId) || isAdmin();
      }
    }

    match /{path=**}/rooms/{roomId} {
      allow read: if true;
    }

    match /bookings/{bookingId} {
      allow read: if isSignedIn() && (isOwner(existing().studentId) || isOwner(existing().managerId) || isAdmin());
      allow create: if isVerified() && isValidBooking(incoming()) && isOwner(incoming().studentId);
      allow update: if (isSignedIn() && (
        (isOwner(existing().studentId) && incoming().status == 'cancelled' && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])) ||
        (isOwner(existing().managerId) && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'paymentStatus', 'updatedAt']))
      ) && incoming().updatedAt == request.time) || isAdmin();
    }

    match /managerVerifications/{verificationId} {
      allow read: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      allow create: if isVerified() && isOwner(incoming().userId) && incoming().status == 'pending';
      allow update: if isAdmin();
    }
    
    match /complaints/{complaintId} {
      allow read: if isSignedIn() && (isOwner(existing().userId) || isOwner(existing().managerId) || isAdmin());
      allow create: if isVerified() && isOwner(incoming().userId);
      allow update: if isAdmin() || isOwner(existing().managerId);
    }
  }
}
